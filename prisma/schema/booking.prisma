model Booking {
  id           String        @id @default(uuid())
  customerId   String
  serviceId    String
  service      Service       @relation(fields: [serviceId], references: [id])
  status       BookingStatus @default(PENDING)
  payment      Payment?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("bookings")
}

