model User {
  id           String       @id @default(uuid())
  name         String
  email        String       @unique
  password     String
  role         Role         @default(CUSTOMER)
  activeStatus ActiveStatus @default(ACTIVE) 
  profile      Profile?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("users")
}

enum Role {
  CUSTOMER
  TECHNICIAN
  ADMIN
}

enum ActiveStatus { 
  ACTIVE
  BLOCKED
}